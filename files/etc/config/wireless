config wifi-device 'radio0'
    option type 'mac80211'
    option channel '36'
    option hwmode '11a'
    option htmode 'VHT80'
    option disabled '0'

config wifi-device 'radio1'
    option type 'mac80211'
    option channel '11'
    option hwmode '11g'
    option htmode 'HT40'
    option disabled '0'

# STA 模式 - WPA2 PEAP 客户端
config wifi-iface
    option device 'radio0'
    option network 'wwan'
    option mode 'sta'
    option ssid 'YourSSID'
    option encryption 'wpa2'
    option eap_type 'peap'
    option identity 'username'
    option password 'password'

# 2.4G 无线 AP
config wifi-iface
    option device 'radio1'
    option network 'lan'
    option mode 'ap'
    option ssid 'OpenWrt-24G'
    option encryption 'psk2'
    option key 'your_wifi_password'

# 5G 无线 AP
config wifi-iface
    option device 'radio0'
    option network 'lan'
    option mode 'ap'
    option ssid 'OpenWrt-5G'
    option encryption 'psk2'
    option key 'your_wifi_password'
